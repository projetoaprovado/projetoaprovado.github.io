<main>
<section style="display:flex; align-items:center; justify-content:center; 
                min-height:100vh; padding:40px 24px;">
  <div style="background:var(--surf-2); border:1px solid var(--brd-1);
              border-radius:var(--r-2xl); padding:48px 40px; 
              width:100%; max-width:440px;">
    
    <!-- Logo -->
    <div style="text-align:center; margin-bottom:32px;">
      <img src="logo.png" alt="Projeto Aprovado" style="height:60px;">
      <h1 style="font-family:var(--ff-titulo); font-size:1.5rem; 
                 margin-top:16px;">Criar sua conta gratuita</h1>
      <p style="color:var(--txt-3); font-size:14px; margin-top:6px;">
        Comece a estudar agora. Sem cartão de crédito.
      </p>
    </div>

    <!-- Formulário -->
    <div style="display:flex; flex-direction:column; gap:16px;">
      
      <div>
        <label style="font-size:13px; color:var(--txt-3); 
                      font-family:var(--ff-mono); letter-spacing:1px;">
          NOME COMPLETO
        </label>
        <input type="text" placeholder="Dr. João Silva"
               style="width:100%; margin-top:6px; padding:12px 16px;
                      background:var(--surf-3); border:1px solid var(--brd-2);
                      border-radius:var(--r-md); color:var(--txt-1);
                      font-size:15px; font-family:var(--ff-corpo);
                      outline:none; transition:border-color 0.2s;">
      </div>

      <div>
        <label style="font-size:13px; color:var(--txt-3); 
                      font-family:var(--ff-mono); letter-spacing:1px;">
          E-MAIL
        </label>
        <input type="email" placeholder="seu@email.com"
               style="width:100%; margin-top:6px; padding:12px 16px;
                      background:var(--surf-3); border:1px solid var(--brd-2);
                      border-radius:var(--r-md); color:var(--txt-1);
                      font-size:15px; font-family:var(--ff-corpo); outline:none;">
      </div>

      <div>
        <label style="font-size:13px; color:var(--txt-3); 
                      font-family:var(--ff-mono); letter-spacing:1px;">
          SENHA
        </label>
        <input type="password" placeholder="Mínimo 8 caracteres"
               style="width:100%; margin-top:6px; padding:12px 16px;
                      background:var(--surf-3); border:1px solid var(--brd-2);
                      border-radius:var(--r-md); color:var(--txt-1);
                      font-size:15px; font-family:var(--ff-corpo); outline:none;">
      </div>

      <div>
        <label style="font-size:13px; color:var(--txt-3); 
                      font-family:var(--ff-mono); letter-spacing:1px;">
          CONFIRMAR SENHA
        </label>
        <input type="password" placeholder="Repita a senha"
               style="width:100%; margin-top:6px; padding:12px 16px;
                      background:var(--surf-3); border:1px solid var(--brd-2);
                      border-radius:var(--r-md); color:var(--txt-1);
                      font-size:15px; font-family:var(--ff-corpo); outline:none;">
      </div>

      <label style="display:flex; align-items:flex-start; gap:10px; 
                    font-size:13px; color:var(--txt-3); cursor:pointer;">
        <input type="checkbox" style="margin-top:3px; accent-color:var(--v-500);">
        Concordo com os <a href="termos.html" 
          style="color:var(--v-300);">Termos de Uso</a> e 
        <a href="privacidade.html" style="color:var(--v-300);">
          Política de Privacidade</a>
      </label>

      <button class="btn btn-verde" style="width:100%; padding:14px; 
                                            font-size:16px; margin-top:8px;">
        Criar minha conta grátis
      </button>

    </div>

    <p style="text-align:center; margin-top:24px; font-size:14px; 
               color:var(--txt-3);">
      Já tem conta? 
      <a href="login.html" style="color:var(--v-300); font-weight:600;">
        Entrar agora
      </a>
    </p>

  </div>
</section>
